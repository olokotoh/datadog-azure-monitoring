# Local .terraform directories
**/.terraform/*

# State files — never commit
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Variable files with real values are ignored by default...
*.tfvars
*.tfvars.json
!*.tfvars.example
# ...but per-team config files are intentional, secret-free, and committed.
# (Secrets always come from env / CI, never from these files.)
!terraform/teams/**/*.tfvars

# Backend config with environment-specific values
*.backend.hcl

# Plan output
*.tfplan

# Crash logs
crash.log
crash.*.log

# CLI config
.terraformrc
terraform.rc
