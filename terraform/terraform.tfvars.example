# Copy to terraform.tfvars (git-ignored) OR supply via TF_VAR_* env vars.
# Secrets should come from the environment / CI secrets, NOT this file.

# ---- Datadog (prefer env: TF_VAR_datadog_api_key / TF_VAR_datadog_app_key) ----
# datadog_api_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# datadog_app_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
datadog_api_url = "https://api.datadoghq.com/"

# ---- Azure service principal for the Datadog integration ----
azure_subscription_id = "00000000-0000-0000-0000-000000000000"
azure_tenant_id       = "00000000-0000-0000-0000-000000000000"
azure_client_id       = "00000000-0000-0000-0000-000000000000"
# azure_client_secret = "supplied via TF_VAR_azure_client_secret"
azure_sp_object_id    = "00000000-0000-0000-0000-000000000000"

# Set false for a credential-free plan/demo (skips Azure role assignments).
manage_azure_permissions = true

# ---- Teams: the primary grouping dimension. Add team3 by appending a block. ----
teams = {
  team1 = {
    display_name = "Payments"
    members      = ["@payments@example.com", "@slack-payments"]
    tags         = ["service:payments", "tier:critical"]
    api = {
      endpoint             = "https://api.example.com/payments/health"
      expected_status_code = 200
      max_response_time_ms = 800
      body_contains        = "ok"
      locations            = ["aws:us-east-1", "aws:eu-west-1"]
      tick_every_seconds   = 300
    }
    response_time_alert_threshold_ms = 1200
    renotify_interval_minutes        = 30
  }

  team2 = {
    display_name = "Search"
    members      = ["@search@example.com"]
    api = {
      endpoint = "https://api.example.com/search/health"
    }
  }
}
